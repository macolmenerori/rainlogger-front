{
  "name": "rainlogger-front",
  "version": "1.0.1",
  "description": "Frontend application for RainLogger, a rainfall monitoring system.",
  "type": "module",
  "main": "index.js",
  "author": "macolmenerori",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/macolmenerori/rainlogger-front.git"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "prettify": "prettier -w --log-level=silent app/",
    "lint": "eslint --fix ./app/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "types": "react-router typegen && tsc --noEmit",
    "verify": "pnpm audit --prod && pnpm lint && pnpm prettify && pnpm types && pnpm test && pnpm build",
    "release": "npx tsx scripts/release.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "^7.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@macolmenerori/component-library": "^1.4.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "dotenv": "^17.4.2",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.39",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^17.0.6",
    "react-router": "^7.14.2",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "yaml": "2.8.3"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
